# Emoji
super + o
	~/.config/i3/rofi/emoji-picker/emoji.sh
	
# Launch Pulsemixer (Audio Mixer)
super + m
	~/.config/i3/scripts/scratchpad pulsemixer ~/.config/i3/scripts/pulsemixer
	
# Take a Screenshot (Region Select)
super + shift + p
	flameshot gui --path ~/Media/Images; paplay ~/.config/i3/dunst/sounds/camera-shutter.mp3 >/dev/null 2>&1

# Take a Fullscreen Screenshot
super + p
	flameshot full --path ~/Media/Images; paplay ~/.config/i3/dunst/sounds/camera-shutter.mp3 >/dev/null 2>&1

# Take a Screenshot ( clipboard )
super + ctrl + p
    flameshot gui -c; paplay ~/.config/i3/dunst/sounds/camera-shutter.mp3 >/dev/null 2>&1
    
# Launch Translate
super + u
	pgrep -f "easygoogletranslate" > /dev/null && wmctrl -xa "easygoogletranslate" || ~/Tools/easygoogletranslate/launcher.sh

# Open Greenclip Clipboard History
super + v
    ~/.config/i3/rofi/clipboard-menu/clipmenu.sh 

super + alt + c
    xclip -selection clipboard -o | xargs | xclip -selection clipboard -target STRING && notify-send "Clipboard" "Sanitized & Formatted"    
    
# Clear Greenclip History
super + shift + v
	greenclip clear && notify-send "Clipboard" "History Cleared" -t 1000 
    
# Shutdown or Reboot
super + x
	~/.config/i3/rofi/power-menu/powermenu.sh
	
# Lockscreen
super + z
    betterlockscreen -l

# Show Keybinding Help Script super + /
super + slash
	~/.config/i3/rofi/keybinds-lists/keybinds-lists.sh
	
# Polybar Toggle
super + F1
   bash ~/.config/i3/scripts/polybar-toggle.sh
  
# Picom Toggle
super + F2
	sh ~/.config/i3/scripts/picom-toggle.sh
   
# Launch Wallpaper Menu
super + F3
	~/.config/i3/rofi/wallpaper-changer/wallpaper-launcher+rofi.sh

# Theme Changer
super + F4
   bash ~/.config/i3/rofi/themes-changer/theme-switcher.sh

