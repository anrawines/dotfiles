# Always ignore download errors and continue
--ignore-errors

# Save all videos to a 'Videos' directory in your home folder
-o ~/Videos/%(title)s.%(ext)s

# Prefer 1080p or lower resolution video combined with the best audio
-f "bestvideo[height<=?1080]+bestaudio/best"

# Embed metadata and thumbnail (if possible)
--cookies-from-browser firefox
--embed-metadata
--embed-thumbnail
