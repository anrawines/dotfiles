# Brightness Up (Media Key)
#XF86MonBrightnessUp
#	xbacklight +10

# Brightness Down (Media Key)
#XF86MonBrightnessDown
#	xbacklight -10
	
# Brightness Up (Numpad + ATAU Tombol Laptop)
XF86MonBrightnessUp
    brightnessctl set +5% && notify-send "Brightness" "$(brightnessctl -m | cut -d, -f4)" -h string:x-canonical-private-synchronous:brightness

# Brightness Down (Numpad - ATAU Tombol Laptop)
XF86MonBrightnessDown
    brightnessctl set 5%- && notify-send "Brightness" "$(brightnessctl -m | cut -d, -f4)" -h string:x-canonical-private-synchronous:brightness

# Reload sxhkd Config
super + Escape
	pkill -USR1 -x sxhkd; notify-send 'sxhkd' 'Reloaded config'

# Toggle Fullscreen
super + alt + f
	i3-msg fullscreen toggle; notify-send 'i3' 'Fullscreen Mode Activated'

# Toggle Floating
super + shift + space
	i3-msg floating toggle
	
# Toggle Floating Mouse
super + shift + button1
	i3-msg floating toggle
	
# Toggle Focus (Tiling/Floating)
super + control + space
	i3-msg focus mode_toggle

# Focus Parent Container
super + alt + a
	i3-msg focus parent
    
# Exit i3
super + shift + q
	i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'

# Close Window
super + q
	i3-msg kill

# Reload i3 Config
super + shift + c
	i3-msg reload

# Restart i3
super + shift + r
	i3-msg restart && (sleep 2 && notify-send 'i3' 'Restarted') 

# Layout Stacking
super + s
	i3-msg layout stacking; notify-send 'i3' 'Stacking Layout Activated'

# Layout Tabbed
super + t
	i3-msg layout tabbed; notify-send 'i3' 'Tab Layout Activated'

# Layout Toggle Split
super + w
	i3-msg layout toggle split; notify-send 'i3' 'Split Layout Activated'

# Move to Scratchpad
super + minus
	i3-msg move scratchpad; i3-msg scratchpad show, resize set 1200 800, move position center

# Show/Hide Scratchpad
super + equal
	i3-msg scratchpad show

# Move Scratchpad Back to Tiling
super + shift + equal
	i3-msg floating disable

# Play/Pause ( Media Key )
XF86AudioPlay
    mpc toggle && ~/.config/rmpc/notify_album_art.sh

# Stop ( Media Key )
XF86AudioStop
    mpc stop && notify-send 'music' 'stop'

# Next Track ( Media Key )
XF86AudioNext
    mpc next && ~/.config/rmpc/notify_album_art.sh

# Previous Track ( Media Key )
XF86AudioPrev
    mpc prev && ~/.config/rmpc/notify_album_art.sh
    
# Mute Audio ( Media Key )
XF86AudioMute
	pamixer -t && notify-send "Volume" "Muted" -u low -r "9993" \
	-h string:x-dunst-stack-tag:volume
	 
# Volume Up ( Media Key )
XF86AudioRaiseVolume
	pamixer -i 2 && ~/.config/i3/scripts/volume-dunst.sh

# Volume Down ( Media Key )
XF86AudioLowerVolume
	pamixer -d 2 && ~/.config/i3/scripts/volume-dunst.sh

# Volume Down
super + F11
	~/.config/i3/scripts/changevolume.sh down
	
# Toggle Mute
super + F10
	~/.config/i3/scripts/changevolume.sh mute

# Volume Up
super + F12
	~/.config/i3/scripts/changevolume.sh up	
