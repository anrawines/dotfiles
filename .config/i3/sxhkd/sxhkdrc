# ALT-TAB
alt + Tab
	~/.config/i3/rofi/alt-tab/alt-tab.sh

##---------- Applications ----------##
	
# Launch Terminal 1 (Wezterm)
super + Return
	alacritty

# Launch Terminal 2 (Wezterm)
super + ctrl + Return
	kitty

# Toggle Scratchpad Terminal
super + shift + Return
	~/.config/i3/scripts/scratchpad

# Launch Rofi Application Menu
super + space
	rofi -show drun -line-padding 4 -hide-scrollbar -matching fuzzy -show-icons -theme ~/.config/i3/rofi/app-launcher/style_1.rasi
	
# Launch Rofi Application Menu
super + alt + space
	~/.local/bin/nimlaunch
	
# Launch Browser (Firefox)
super + b
	~/.config/i3/scripts/toggle-firefox

# Launch Private Browser (Firefox Incognito Mode)
super + shift + b
	firefox -private-window
	
# Launch Secondary Browser ( Helium )
super + ctrl + b
	pgrep -x "helium" > /dev/null && wmctrl -xa "helium" || helium-browser
	
# Color Picker
super + c
	~/.config/i3/scripts/color-picker.sh
	
# Launch Dmenu
super + d
	~/.local/bin/dmenu-local.sh

# Online Search
super + e
	~/.config/i3/rofi/oneline-search/online-search.sh
	   	
# Launch File Manager (Thunar)
super + f
	thunar

# Toggle Scratchpad File Manager (Thunar)
super + shift + f
	thunar --name thunar_float
	
# Launch Geany (Text Editor)
super + g
	pgrep -x geany > /dev/null && i3-msg '[class="(?i)geany"] focus' || geany

# Launch Calculator
super + KP_Multiply
	qalculate-gtk

