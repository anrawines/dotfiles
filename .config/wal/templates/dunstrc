[urgency_low]
    background = "${background}"
    foreground = "${foreground}"
    frame_color = "${color2}"
    timeout = 5
    highlight = "${color2}"

[urgency_normal]
    background = "${background}"
    foreground = "${foreground}"
    frame_color = "${color1}"
    timeout = 10
    highlight = "${color2}"

[urgency_critical]
    background = "${background}"
    foreground = "${foreground}"
    frame_color = "${color4}"
    timeout = 0
    highlight = "${color4}"
