#!/bin/bash

# Set xautolock to trigger the 'lock' script after 10 minutes of inactivity
# Includes a 30-second notification warning
xautolock -time 10 -locker "$HOME/.local/bin/lock" \
  -notify 30 \
  -notifier "notify-send -u critical 'Locking in 30 seconds'" &

# Set xidlehook to suspend the system after 20 minutes (1200 seconds)
# --not-when-fullscreen: prevents suspension while watching videos
xidlehook \
  --not-when-fullscreen \
  --not-when-audio \
  --timer 1200 \
  "systemctl suspend" \
  "" &
