{
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.untrustedFiles": "open",
  "security.workspace.trust.emptyWindow": false,
  "security.workspace.trust.enabled": false,
  // Disable telemetry
  "telemetry.telemetryLevel": "off",
  // theme
  "workbench.colorTheme": "Yukinord",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "material-product-icons",
  "workbench.preferredLightColorTheme": "Yukinord",
  "workbench.preferredDarkColorTheme": "Yukinord",
  "workbench.colorCustomizations": {
  },
  // editor fonts
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Menlo', 'Monaco', 'Courier New', 'monospace'",
  "editor.fontLigatures": true,
  "editor.fontSize": 15,
  "editor.codeLensFontSize": 13,
  "editor.lineHeight": 22,
  "editor.suggestFontSize": 15,
  "editor.lineNumbers": "on",
  // terminal
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'Menlo', 'Monaco', 'Courier New', 'monospace'",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.lineHeight": 1.2,
  "window.titleBarStyle": "native",
  "window.autoDetectColorScheme": true,
  "window.newWindowDimensions": "inherit",
  // complete remove title
  "window.title": " ",
  "window.zoomLevel": 1,
  // minimal settings
  "breadcrumbs.enabled": false,
  "editor.glyphMargin": false,
  "editor.folding": false,
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "off"
  },
    // Smoother cursor animation
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.formatOnType": true,
  "editor.lightbulb.enabled": "off",
  "editor.overviewRulerBorder": false,
  "editor.renderLineHighlight": "line",
  "editor.renderControlCharacters": false,
  "editor.guides.indentation": true,
  "editor.renderWhitespace": "none",
  "workbench.editor.pinnedTabSizing": "compact",
  "workbench.editor.tabSizing": "shrink",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.tips.enabled": false,
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabActionCloseVisibility": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  //Scrollbar
  "editor.scrollbar.verticalScrollbarSize": 5,
  "editor.scrollbar.horizontalScrollbarSize": 5,
  //"editor.scrollbar.vertical": "hidden",
  //"editor.scrollbar.horizontal": "hidden",
  "http.systemCertificatesNode": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "diffEditor.codeLens": true,
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 150,
  "chat.agent.enabled": false,
  "chat.agent.codeBlockProgress": false,
  "workbench.settings.applyToAllProfiles": [

    "chat.agent.enabled",
    "chat.agent.codeBlockProgress"
  ],
  "geminicodeassist.chat.automaticScrolling": false,
  "geminicodeassist.enableTelemetry": false,
  "geminicodeassist.inlineSuggestions.suggestionSpeed": "Fast",
  "workbench.secondarySideBar.showLabels": false,
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right",
  "editor.cursorStyle": "block",
  "workbench.preferredHighContrastColorTheme": "Default Dark+",
  "workbench.preferredHighContrastLightColorTheme": "Visual Studio Light",
  "workbench.statusBar.visible": false,
  "chat.agentsControl.enabled": false,
  "editor.acceptSuggestionOnEnter": "smart",
  // remove window close, minimze and restore
  "window.controlsStyle": "hidden",
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "window.menuBarVisibility": "toggle",
  "window.customTitleBarVisibility": "never",
  "editor.mouseWheelZoom": true,
  "editor.fontVariations": true,
}
